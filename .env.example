# ─────────────────────────────────────────────────────────────
# Phase 5 — Alerting Configuration
# Copy this file to .env and fill in your real values.
# NEVER commit .env to Git — it contains secrets.
# ─────────────────────────────────────────────────────────────

# ── Slack ─────────────────────────────────────────────────────
# Get this from: https://api.slack.com/apps → your app → Incoming Webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ── Email (Gmail SMTP) ────────────────────────────────────────
# Use a Gmail account with App Password (not your real password)
# Enable App Passwords: myaccount.google.com → Security → App Passwords
EMAIL_SENDER=your_email@gmail.com
EMAIL_PASSWORD=your_16_char_app_password
EMAIL_RECEIVER=receiver_email@gmail.com
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587

# ── Alert thresholds ──────────────────────────────────────────
# Which severity levels trigger Slack alerts
ALERT_ON_CRITICAL=true
ALERT_ON_HIGH=true
ALERT_ON_MEDIUM=false

# Deduplication window in minutes — don't re-alert same issue within this window
DEDUP_WINDOW_MINUTES=60
